# ---------------------------------------------------------------- #
# SpringBoot/Java 用 .gitignore
# ---------------------------------------------------------------- #

# ---------------------------------------------------------------- #
# ビルド出力ディレクトリ
# ---------------------------------------------------------------- #
/target/             # Maven ビルドの出力ディレクトリ
/build/              # Gradle ビルドの出力ディレクトリ (主に Groovy/Kotlin)
*.jar                # 最終的な JAR ファイル
*.war                # WAR ファイル
*.zip
*.tar.gz

# ---------------------------------------------------------------- #
# IDE および OS のファイル
# ---------------------------------------------------------------- #
# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr

# Eclipse
.classpath
.project
.settings/
bin/

# VS Code
.vscode/

# macOS (OS X)
.DS_Store

# Windows
Thumbs.db

# ---------------------------------------------------------------- #
# Maven/Gradle キャッシュとラッパー
# ---------------------------------------------------------------- #
# Maven
/m2/

# Gradle
.gradle/
!gradle-wrapper.jar # wrapper の JAR ファイル自体は含める
/gradle-wrapper/gradle-wrapper.jar
!gradle-wrapper/gradle-wrapper.properties

# ---------------------------------------------------------------- #
# ログと一時ファイル
# ---------------------------------------------------------------- #
*.log
log/
tmp/
temp/
# テストレポートなど
/surefire-reports/

# ---------------------------------------------------------------- #
# 環境固有のファイル
# ---------------------------------------------------------------- #
# 外部設定ファイル (機密情報を含む可能性があるため除外推奨)
application-dev.properties
application-prod.properties
application*.yml
!application.properties # デフォルトのapplication.propertiesは含めることが多い
!application.yml        # デフォルトのapplication.ymlは含めることが多い
# ※ 環境固有の設定ファイルや機密情報を含む設定ファイルは全て除外してください。

# 環境変数ファイル
.env
.env.local